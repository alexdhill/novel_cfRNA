@article{reggiardo_lncrna_2022,
	title = {{LncRNA} Biomarkers of Inflammation and Cancer},
	volume = {1363},
	issn = {0065-2598},
	doi = {10.1007/978-3-030-92034-0_7},
	abstract = {Long noncoding {RNAs} ({lncRNAs}) are promising candidates as biomarkers of inflammation and cancer. {LncRNAs} have several properties that make them well-suited as molecular markers of disease: (1) many {lncRNAs} are expressed in a tissue-specific manner, (2) distinct {lncRNAs} are upregulated based on different inflammatory or oncogenic stimuli, (3) {lncRNAs} released from cells are packaged and protected in extracellular vesicles, and (4) circulating {lncRNAs} in the blood are detectable using various {RNA} sequencing approaches. Here we focus on the potential for {lncRNA} biomarkers to detect inflammation and cancer, highlighting key biological, technological, and analytical considerations that will help advance the development of {lncRNA}-based liquid biopsies.},
	pages = {121--145},
	journaltitle = {Advances in Experimental Medicine and Biology},
	shortjournal = {Adv Exp Med Biol},
	author = {Reggiardo, Roman E. and Maroli, Sreelakshmi Velandi and Kim, Daniel H.},
	date = {2022},
	pmid = {35220568},
	keywords = {Biomarkers, Tumor, Humans, Neoplasms, Biomarkers, Transposable elements, {RNA}, Long Noncoding, Extracellular Vesicles, Inflammation, {lncRNA}, Therapeutics},
}

@article{reggiardo_mutant_2022,
	title = {Mutant {KRAS} regulates transposable element {RNA} and innate immunity via {KRAB} zinc-finger genes},
	volume = {40},
	issn = {2211-1247},
	doi = {10.1016/j.celrep.2022.111104},
	abstract = {{RAS} genes are the most frequently mutated oncogenes in cancer, yet the effects of oncogenic {RAS} signaling on the noncoding transcriptome remain unclear. We analyzed the transcriptomes of human airway and bronchial epithelial cells transformed with mutant {KRAS} to define the landscape of {KRAS}-regulated noncoding {RNAs}. We find that oncogenic {KRAS} signaling upregulates noncoding transcripts throughout the genome, many of which arise from transposable elements ({TEs}). These {TE} {RNAs} exhibit differential expression, are preferentially released in extracellular vesicles, and are regulated by {KRAB} zinc-finger ({KZNF}) genes, which are broadly downregulated in mutant {KRAS} cells and lung adenocarcinomas in vivo. Moreover, mutant {KRAS} induces an intrinsic {IFN}-stimulated gene ({ISG}) signature that is often seen across many different cancers. Our results indicate that mutant {KRAS} remodels the repetitive noncoding transcriptome, demonstrating the broad scope of intracellular and extracellular {RNAs} regulated by this oncogenic signaling pathway.},
	pages = {111104},
	number = {3},
	journaltitle = {Cell Reports},
	shortjournal = {Cell Rep},
	author = {Reggiardo, Roman E. and Maroli, Sreelakshmi Velandi and Halasz, Haley and Ozen, Mehmet and Hrabeta-Robinson, Eva and Behera, Amit and Peddu, Vikas and Carrillo, David and {LaMontagne}, Erin and Whitehead, Lila and Kim, Eejung and Malik, Shivani and Fernandes, Jason and Marinov, Georgi and Collisson, Eric and Brooks, Angela and Demirci, Utkan and Kim, Daniel H.},
	date = {2022-07-19},
	pmid = {35858545},
	pmcid = {PMC9374308},
	keywords = {Humans, {RNA}, extracellular {RNA}, {DNA} Transposable Elements, Mutation, cancer, Cell Line, Tumor, Immunity, Innate, Proto-Oncogene Proteins p21(ras), {CP}: Molecular biology, extracellular vesicles, interferon-stimulated genes, {KRAS}, {KZNF}, noncoding {RNA}, {RAS} signaling, {RNA} biomarker, transposable element, Genes, ras, Zinc},
	file = {Full Text:/Users/alexdhill/.zotero/storage/7ZPIYV3N/Reggiardo et al. - 2022 - Mutant KRAS regulates transposable element RNA and.pdf:application/pdf},
}

